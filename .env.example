# Timezone
TZ=America/New_York

# Projects directory on the host (bind-mounted into dev-box as /workspace)
PROJECTS_DIR=/home/docker/projects

# Backup directory on the host
BACKUP_DIR=/home/docker/backups

# Database credentials (auto-generated by install.sh if left blank)
DB_USER=devuser
DB_PASSWORD=CHANGEME
DB_NAME=devdb

# MinIO (S3-compatible object storage)
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# Homepage
HOMEPAGE_ALLOWED_HOSTS=*

# Exposed ports (change to avoid conflicts with existing services)
DB_PORT=5432
REDIS_PORT=6379
HOMEPAGE_PORT=3000
DOZZLE_PORT=9999
KUMA_PORT=3001
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASH_PORT=8080
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
ADMINER_PORT=8081
