# Timezone
TZ=America/New_York

# Projects directory on the host (bind-mounted into dev-box as /workspace)
PROJECTS_DIR=/home/docker/projects

# Backup directory on the host
BACKUP_DIR=/home/docker/backups

# Database credentials (auto-generated by install.sh if left blank)
DB_USER=devuser
DB_PASSWORD=CHANGEME
DB_NAME=devdb

# Homepage
HOMEPAGE_ALLOWED_HOSTS=*

# Exposed ports (change to avoid conflicts with existing services)
DB_PORT=5432
HOMEPAGE_PORT=3000
DOZZLE_PORT=9999
KUMA_PORT=3001
